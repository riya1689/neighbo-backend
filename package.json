{
  "name": "neighbo-backend",
  "version": "1.0.0",
  "description": "Backend for Neighbo Platform",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc --skipLibCheck && echo ✅ Build complete!",
